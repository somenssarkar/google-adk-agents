# Dockerfile.backend — ADK FastAPI backend (Service 2)
#
# Runs main.py via uvicorn on PORT (Cloud Run injects $PORT).
# Connects to AlloyDB via SESSION_DB_URI env var.
# Uses Vertex AI for Gemini — no API key needed (service account identity).
#
# Build:  docker build -f Dockerfile.backend -t tutor-backend .
# Run locally:
#   docker run -p 8000:8000 \
#     -e GOOGLE_GENAI_USE_VERTEXAI=1 \
#     -e GOOGLE_CLOUD_PROJECT=genai-apac-demo-project \
#     -e GOOGLE_CLOUD_LOCATION=asia-southeast1 \
#     -e SESSION_DB_URI=postgresql+asyncpg://postgres:PASSWORD@34.124.206.1:5432/tutor_db \
#     tutor-backend

FROM python:3.12-slim

# Suppress pip version warnings
ENV PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1

WORKDIR /app

# Install system dependencies required by some ADK packages
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# Install Python dependencies
# Core ADK + async PostgreSQL driver for AlloyDB session storage
COPY requirements-backend.txt .
RUN pip install --no-cache-dir -r requirements-backend.txt

# Copy application code
COPY main.py .
COPY tutor_platform/ tutor_platform/

# Cloud Run sets $PORT — default 8000 for local testing
ENV PORT=8000

# --timeout 300: agentic chains with code execution can take 30-60s
# --workers 1: ADK InMemoryArtifactService is not thread-safe across workers
CMD ["sh", "-c", "uvicorn main:app --host 0.0.0.0 --port ${PORT} --timeout-keep-alive 300 --workers 1"]
