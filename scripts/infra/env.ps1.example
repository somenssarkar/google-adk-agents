# =============================================================================
# Environment Variables for AlloyDB Setup — Windows PowerShell
# =============================================================================
# Copy this file to env.ps1 and fill in your values:
#   cp scripts\infra\env.ps1.example scripts\infra\env.ps1
#
# SECURITY: DB_PASSWORD is NOT stored here.
#   - Stored in Google Secret Manager
#   - Retrieved at runtime via: gcloud secrets versions access latest
# =============================================================================

$env:PROJECT_ID    = "genai-apac-demo-project"
$env:REGION        = "asia-southeast1"
$env:CLUSTER_NAME  = "tutor-cluster"
$env:INSTANCE_NAME = "tutor-instance"
$env:DB_NAME       = "tutor_db"
$env:DB_USER       = "postgres"
$env:NETWORK_NAME  = "default"
$env:SECRET_NAME   = "alloydb-tutor-password"
