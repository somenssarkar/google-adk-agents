#!/bin/bash
# =============================================================================
# Environment Variables for AlloyDB Setup
# =============================================================================
# Copy this file to env.sh and fill in your values:
#   cp env.sh.example env.sh
#
# SECURITY: DB_PASSWORD is NOT stored here.
#   - setup_alloydb.sh will prompt for it interactively at runtime
#   - It is then stored in Google Secret Manager (never on disk)
#   - All subsequent scripts retrieve it from Secret Manager via gcloud
# =============================================================================

# Google Cloud Project
export PROJECT_ID="genai-apac-demo-project"

# AlloyDB Configuration
export REGION="asia-southeast1"
export CLUSTER_NAME="tutor-cluster"
export INSTANCE_NAME="tutor-instance"
export DB_NAME="tutor_db"
export DB_USER="postgres"   # AlloyDB default superuser

# Network Configuration
# Leave defaults unless they conflict with existing VPC resources in your project.
export NETWORK_NAME="default"
export IP_RANGE_NAME="google-managed-services-default"

# Secret Manager — name under which the AlloyDB password is stored
export SECRET_NAME="alloydb-tutor-password"
